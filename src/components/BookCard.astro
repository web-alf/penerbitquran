---
import type { Book } from '../data/books';

interface Props {
  book: Book;
}

const { book } = Astro.props;
---

<a href={`/katalog/${book.id}`} class="group bg-white rounded-lg overflow-hidden shadow-soft border border-surface-2/50 cursor-pointer transition-all duration-300 hover:-translate-y-[7px] hover:shadow-heavy block">
  <div class="h-[236px] flex items-center justify-center p-3.5 relative">
    {book.badge && (
      <span class:list={[
        'absolute top-2.5 left-2.5 text-[10px] font-semibold px-2.5 py-[3px] rounded-[10px] font-sans',
        book.badge === 'Best Seller' ? 'bg-gold text-[#160900]' : 'bg-emerald text-white',
      ]}>
        {book.badge}
      </span>
    )}
    {book.cover ? (
      <div class="relative w-full h-full rounded overflow-hidden">
        <img
          src={book.cover}
          alt=""
          aria-hidden="true"
          loading="lazy"
          class="absolute inset-0 w-full h-full object-cover scale-125 blur-2xl opacity-55"
        />
        <img
          src={book.cover}
          alt={`Sampul buku ${book.t}`}
          loading="lazy"
          class="relative w-full h-full object-contain drop-shadow-lg"
        />
      </div>
    ) : (
      <div
        class="w-full h-full rounded flex flex-col items-center justify-center p-4 text-center"
        style={`background:${book.bg}`}
      >
        <div class="text-[34px]">{book.ic}</div>
        <div class="text-white/90 font-display text-xs font-bold mt-2 leading-snug">{book.t}</div>
        <div class="text-white/45 text-[10px] mt-1 font-sans">{book.a.split(',')[0]}</div>
      </div>
    )}
  </div>
  <div class="p-3.5 pt-3">
    <div class="text-[10px] font-semibold uppercase tracking-wider mb-1 text-emerald-medium font-sans">{book.cat}</div>
    <div class="text-[13px] font-bold text-surface-6 leading-snug mb-1 font-display">{book.t}</div>
    <div class="text-[11px] text-surface-4 mb-2.5 font-sans">{book.a}</div>
    <span class="block text-center py-2 bg-emerald-pale text-emerald rounded-lg text-xs font-semibold font-sans group-hover:bg-emerald group-hover:text-white transition-all duration-200">
      Lihat Detail →
    </span>
  </div>
</a>
