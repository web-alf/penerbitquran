---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
---

<Base title="Kontak — Penerbit Quran Indonesia">

<PageHero
  title="Hubungi Kami"
  subtitle="PT Penerbit Quran Indonesia — Semarang, Jawa Tengah"
  breadcrumb="Kontak"
/>

<section class="py-[88px] bg-bg">
  <div class="max-w-[1180px] mx-auto px-7">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.4fr] gap-14">

      <div>
        <div class="font-sans text-[11px] font-semibold tracking-[.18em] uppercase text-emerald flex items-center gap-2.5 mb-3">
          <span class="w-6 h-px bg-emerald"></span>
          Informasi Kontak
        </div>
        <h2 class="font-display text-[clamp(24px,4vw,34px)] font-black text-surface-6 mb-8">Kami Siap Membantu</h2>

        <div class="space-y-6 mb-10">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded bg-emerald-pale flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-emerald" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0l-4.243-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            </div>
            <div>
              <div class="font-display text-[14px] font-bold text-surface-6 mb-0.5">Alamat</div>
              <div class="font-sans text-[13px] text-surface-4 leading-relaxed">Jl. Ngablak Indah II No.24A, RT 008/RW 004, Kel. Bangetayu Kulon, Kec. Genuk, Kota Semarang, Jawa Tengah 50115</div>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded bg-emerald-pale flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-emerald" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            </div>
            <div>
              <div class="font-display text-[14px] font-bold text-surface-6 mb-0.5">Email</div>
              <a href="mailto:penerbitquranindonesia@gmail.com" class="font-sans text-[13px] text-emerald hover:underline">penerbitquranindonesia@gmail.com</a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded bg-emerald-pale flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-emerald" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            </div>
            <div>
              <div class="font-display text-[14px] font-bold text-surface-6 mb-0.5">WhatsApp</div>
              <a href="https://wa.me/6282136741135" class="font-sans text-[13px] text-emerald hover:underline">0821-3674-1135</a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded bg-emerald-pale flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-emerald" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            </div>
            <div>
              <div class="font-display text-[14px] font-bold text-surface-6 mb-0.5">Jam Operasional</div>
              <div class="font-sans text-[13px] text-surface-4 leading-relaxed">
                Sen–Kam: 08.00–16.00 WIB<br />
                Jum: 08.00–17.00 WIB<br />
                Sab: 08.00–15.00 WIB
              </div>
            </div>
          </div>
        </div>

        <div class="h-[188px] bg-emerald-pale rounded-lg flex flex-col items-center justify-center">
          <svg class="w-8 h-8 text-emerald/40 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0l-4.243-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          <div class="font-display text-sm font-bold text-emerald/60">PT Penerbit Quran Indonesia</div>
          <div class="font-sans text-[11px] text-emerald/40 mt-0.5">Semarang, Jawa Tengah</div>
        </div>
      </div>

      <div>
        <div class="bg-white rounded-lg p-9 shadow-soft border border-surface-2/50">
          <h3 class="font-display text-[22px] font-black text-surface-6 mb-1.5">Kirim Pesan</h3>
          <p class="font-sans text-[13px] text-surface-4 mb-7">Kami merespons dalam 1×24 jam kerja</p>

          <form class="space-y-4">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block font-sans text-[13px] font-semibold text-surface-5 mb-1.5">Nama</label>
                <input type="text" required class="w-full p-2.5 px-3.5 border border-surface-2 rounded font-sans text-sm focus:border-emerald focus:ring-2 focus:ring-emerald/10 outline-none transition" />
              </div>
              <div>
                <label class="block font-sans text-[13px] font-semibold text-surface-5 mb-1.5">Email</label>
                <input type="email" required class="w-full p-2.5 px-3.5 border border-surface-2 rounded font-sans text-sm focus:border-emerald focus:ring-2 focus:ring-emerald/10 outline-none transition" />
              </div>
            </div>

            <div>
              <label class="block font-sans text-[13px] font-semibold text-surface-5 mb-1.5">WhatsApp</label>
              <input type="tel" required class="w-full p-2.5 px-3.5 border border-surface-2 rounded font-sans text-sm focus:border-emerald focus:ring-2 focus:ring-emerald/10 outline-none transition" />
            </div>

            <div>
              <label class="block font-sans text-[13px] font-semibold text-surface-5 mb-1.5">Subjek</label>
              <select required class="w-full p-2.5 px-3.5 border border-surface-2 rounded font-sans text-sm focus:border-emerald focus:ring-2 focus:ring-emerald/10 outline-none transition bg-white">
                <option value="" disabled selected>Pilih subjek</option>
                <option>Pengajuan Naskah</option>
                <option>Pemesanan Buku</option>
                <option>NUURKIDS Order</option>
                <option>Kerjasama Distribusi</option>
                <option>Pertanyaan Umum</option>
              </select>
            </div>

            <div>
              <label class="block font-sans text-[13px] font-semibold text-surface-5 mb-1.5">Pesan</label>
              <textarea rows="5" required class="w-full p-2.5 px-3.5 border border-surface-2 rounded font-sans text-sm focus:border-emerald focus:ring-2 focus:ring-emerald/10 outline-none transition resize-y" placeholder="Tulis pesan Anda..."></textarea>
            </div>

            <button type="submit" class="w-full py-3 bg-emerald text-white font-display text-sm font-bold rounded hover:bg-emerald-light hover:-translate-y-0.5 hover:shadow-medium transition-all duration-300">
              Kirim Pesan
            </button>
          </form>
        </div>

        <div class="mt-5 bg-emerald-pale rounded-lg p-6 flex flex-col sm:flex-row items-center gap-5">
          <div class="flex-1">
            <div class="font-display text-[15px] font-bold text-emerald mb-1">Chat Langsung via WhatsApp</div>
            <div class="font-sans text-[13px] text-surface-4">Respons lebih cepat untuk pertanyaan mendesak</div>
          </div>
          <a href="https://wa.me/6282136741135" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-6 py-2.5 rounded bg-[#25d366] text-white font-display text-sm font-bold hover:bg-[#20bd5a] hover:-translate-y-0.5 hover:shadow-medium transition-all duration-300 shrink-0">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" /></svg>
            WhatsApp Kami
          </a>
        </div>
      </div>

    </div>
  </div>
</section>

</Base>
