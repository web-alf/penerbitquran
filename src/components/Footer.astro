---
const navLinks = [
  { href: '/', label: 'Beranda' },
  { href: '/tentang', label: 'Tentang Kami' },
  { href: '/katalog', label: 'Katalog Buku' },
  { href: '/layanan', label: 'Layanan' },
  { href: '/penulis', label: 'Ajukan Naskah' },
  { href: '/kontak', label: 'Kontak' },
];

const categories = [
  "Al-Qur'an & Tajwid",
  "Tahfidz Anak",
  "Parenting Islami",
  "Sirah Nabawiyah",
  "Motivasi Islami",
];
---

<footer class="bg-surface-6 text-white pt-16 pb-6">
  <div class="max-w-[1180px] mx-auto px-7">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-[2fr_1fr_1fr_1.3fr] gap-10 mb-12">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-3">
          <div class="w-[42px] h-[42px] bg-emerald rounded-[10px] relative overflow-hidden flex-shrink-0">
            <div class="absolute w-[22px] h-[22px] border-[2.5px] border-white/80 rounded-[3px] rotate-45 top-1/2 left-1/2 -mt-[11px] -ml-[11px]"></div>
            <div class="absolute w-[7px] h-[7px] bg-gold rounded-full top-[9px] right-[9px]"></div>
          </div>
          <div>
            <div class="font-display text-[17px] font-bold text-white leading-none">Penerbit Quran</div>
            <div class="text-[10px] text-surface-4 tracking-wider font-sans">penerbitquran.com</div>
          </div>
        </div>
        <p class="font-sans text-[13px] text-white/40 leading-[1.85] mt-4 max-w-[280px]">
          PT Penerbit Quran Indonesia — penerbit buku Islami profesional di Semarang. Menerbitkan karya yang menginspirasi dan mendidik.
        </p>
        <a href="/nuurkids" class="inline-flex items-center gap-1.5 mt-3 px-3 py-[5px] border border-gold/20 rounded-lg bg-gold/10">
          <span class="font-display text-xs font-black"><span class="text-white/50">NUUR</span><span class="text-nk-gold">KIDS</span></span>
          <span class="font-sans text-[11px] text-nk-soft/40">Sub-brand Premium</span>
        </a>
        <div class="flex gap-2 mt-4">
          {['ig', 'fb', 'yt', 'wa'].map(s => (
            <div class="w-[34px] h-[34px] rounded-lg bg-white/5 flex items-center justify-center text-xs text-white/40 cursor-pointer hover:bg-emerald-medium hover:text-white transition-all duration-200">
              {s}
            </div>
          ))}
        </div>
      </div>

      <!-- Navigasi -->
      <div>
        <h4 class="font-sans text-xs font-bold uppercase tracking-[.1em] text-white/30 mb-[18px]">Navigasi</h4>
        <ul class="flex flex-col gap-2.5">
          {navLinks.map(link => (
            <li>
              <a href={link.href} class="font-sans text-[13px] text-white/50 hover:text-gold/85 transition-colors duration-200">
                {link.label}
              </a>
            </li>
          ))}
          <li>
            <a href="/nuurkids" class="font-display font-black text-[13px]">
              <span class="text-white/45">NUUR</span><span class="text-nk-gold">KIDS</span>
            </a>
          </li>
        </ul>
      </div>

      <!-- Kategori -->
      <div>
        <h4 class="font-sans text-xs font-bold uppercase tracking-[.1em] text-white/30 mb-[18px]">Kategori Buku</h4>
        <ul class="flex flex-col gap-2.5">
          {categories.map(cat => (
            <li>
              <span class="font-sans text-[13px] text-white/50 hover:text-gold/85 transition-colors duration-200 cursor-pointer">{cat}</span>
            </li>
          ))}
          <li>
            <a href="/katalog?filter=NUURKIDS" class="font-sans text-[13px]">
              <span class="font-display font-black"><span class="text-white/45">NUUR</span><span class="text-nk-gold">KIDS</span></span>
              <span class="text-white/50"> Collection</span>
            </a>
          </li>
        </ul>
      </div>

      <!-- Kontak -->
      <div>
        <h4 class="font-sans text-xs font-bold uppercase tracking-[.1em] text-white/30 mb-[18px]">Kontak</h4>
        <div class="flex flex-col gap-2.5">
          <div class="flex gap-2"><span class="text-[13px] flex-shrink-0">📍</span><span class="font-sans text-xs text-white/40 leading-relaxed">Jl. Ngablak Indah II No.24A, Kec. Genuk, Semarang 50115</span></div>
          <div class="flex gap-2"><span class="text-[13px] flex-shrink-0">📧</span><span class="font-sans text-xs text-white/40">penerbitquranindonesia@gmail.com</span></div>
          <div class="flex gap-2"><span class="text-[13px] flex-shrink-0">📱</span><span class="font-sans text-xs text-white/40">0821-3674-1135</span></div>
          <div class="flex gap-2"><span class="text-[13px] flex-shrink-0">🕐</span><span class="font-sans text-xs text-white/40 leading-[1.7]">Sen–Kam: 08.00–16.00<br/>Jum: 08.00–17.00<br/>Sab: 08.00–15.00</span></div>
        </div>
      </div>
    </div>

    <!-- Bottom -->
    <div class="border-t border-white/5 pt-[22px] flex justify-between items-center flex-wrap gap-3">
      <div class="font-sans text-xs text-white/30">&copy; 2025 PT Penerbit Quran Indonesia. Hak Cipta Dilindungi.</div>
      <div class="flex gap-4">
        <span class="font-sans text-xs text-white/30 cursor-pointer hover:text-white/50">Kebijakan Privasi</span>
        <span class="font-sans text-xs text-white/30 cursor-pointer hover:text-white/50">Syarat & Ketentuan</span>
      </div>
    </div>
  </div>
</footer>
