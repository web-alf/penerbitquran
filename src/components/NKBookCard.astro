---
import type { Book } from '../data/books';

interface Props {
  book: Book;
  variant?: 'catalog' | 'mini' | 'hero';
}

const { book, variant = 'catalog' } = Astro.props;
---

{variant === 'mini' ? (
  <a href={`/katalog/${book.id}`} class="block bg-white rounded-[14px] overflow-hidden shadow-nk border border-gold/15 cursor-pointer transition-all duration-300 hover:-translate-y-2 hover:shadow-nk-heavy">
    <div class="px-3.5 pt-3.5">
      <div class="font-sans text-[9px] font-bold tracking-[.12em] uppercase text-nk-gold mb-1">NUURKIDS</div>
      <div class="font-sans text-[9px] text-nk-brown/45 uppercase tracking-wider">{book.seri}</div>
    </div>
    <div class="h-[168px] mx-2.5 my-2.5 rounded flex flex-col items-center justify-center p-4 text-center" style={`background:${book.bg}`}>
      <div class="text-[28px]">{book.ic}</div>
      <div class="font-display text-xs font-bold text-white/90 mt-2 leading-snug">{book.t}</div>
      {book.al && <div class="font-arabic text-[11px] text-gold/75 mt-1" dir="rtl">{book.al}</div>}
    </div>
    <div class="px-3.5 pb-3.5 pt-2.5">
      <div class="font-display text-[11px] text-nk-brown font-semibold leading-snug">{book.t}</div>
    </div>
  </a>
) : variant === 'hero' ? (
  <a href={`/katalog/${book.id}`} class="block rounded-[14px] overflow-hidden shadow-nk-heavy cursor-pointer transition-all duration-300 hover:-translate-y-1.5 border border-gold/20 relative">
    <div class="h-[240px] flex flex-col items-center justify-center p-5 text-center relative" style={`background:${book.bg}`}>
      <span class="absolute top-2.5 left-2.5 bg-white/90 text-nk-gold text-[9px] font-bold px-2 py-0.5 rounded-[10px] tracking-wider font-sans">{book.seri}</span>
      <div class="text-[44px]">{book.ic}</div>
      <div class="font-display text-[13px] font-bold text-white/90 mt-2 leading-snug">{book.t}</div>
      {book.al && <div class="font-arabic text-xs text-gold/70 mt-[5px]" dir="rtl">{book.al}</div>}
    </div>
    <div class="px-3.5 py-2.5 bg-white border-t border-gold/10">
      <div class="text-[9px] text-nk-gold font-bold uppercase tracking-[.1em] font-sans">NUURKIDS · {book.age}</div>
      <div class="text-[11px] text-nk-brown mt-0.5 font-display">{book.t}</div>
    </div>
  </a>
) : (
  <a href={`/katalog/${book.id}`} class="group block bg-nk-cream rounded-lg overflow-hidden shadow-soft border border-gold/20 cursor-pointer transition-all duration-300 hover:-translate-y-[7px] hover:shadow-heavy">
    <div class="h-[236px] flex items-center justify-center p-3.5 relative">
      {book.badge && (
        <span class="absolute top-2.5 left-2.5 bg-nk-gold text-white text-[9px] font-semibold px-2.5 py-[3px] rounded-[10px] font-sans">
          {book.badge}
        </span>
      )}
      <div class="w-full h-full rounded flex flex-col items-center justify-center p-3.5 text-center" style={`background:${book.bg}`}>
        <div class="text-[9px] font-bold tracking-[.12em] uppercase text-white/55 font-sans mb-1">NUURKIDS</div>
        <div class="text-[9px] text-white/40 font-sans tracking-wider uppercase mb-2">{book.seri}</div>
        <div class="text-[32px]">{book.ic}</div>
        <div class="text-white/90 font-display text-xs font-bold mt-2 leading-snug">{book.t}</div>
        {book.al && <div class="font-arabic text-xs text-gold/75 mt-[5px]" dir="rtl">{book.al}</div>}
      </div>
    </div>
    <div class="p-3.5 pt-3">
      <div class="text-[10px] font-semibold uppercase tracking-wider mb-1 text-nk-gold font-sans">{book.seri} · {book.age}</div>
      <div class="text-[13px] font-bold text-nk-brown leading-snug mb-1 font-display">{book.t}</div>
      <div class="text-[11px] text-nk-brown/50 mb-2.5 font-sans">{book.a}</div>
      <span class="block text-center py-2 bg-gold/10 text-nk-gold rounded-lg text-xs font-semibold font-sans group-hover:bg-nk-gold group-hover:text-white transition-all duration-200">
        Lihat Detail →
      </span>
    </div>
  </a>
)}
